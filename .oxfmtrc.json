{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 4,
	"printWidth": 120,
	"singleQuote": false,
	"jsxSingleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "es5",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"singleAttributePerLine": false,
	"sortImports": {
		"customGroups": [
			{
				"groupName": "react-libs",
				"elementNamePattern": ["react", "react/**", "react-dom", "react-dom/**"]
			},
			{
				"groupName": "next-libs",
				"elementNamePattern": ["next", "next/**"]
			},
			{
				"groupName": "workspace-internal",
				"elementNamePattern": ["@webld", "@webld/**", "@/**"]
			}
		],
		"groups": [
			"react-libs",
			"next-libs",
			["builtin", "external"],
			["workspace-internal", "internal", "subpath"],
			"side_effect",
			["parent", "sibling", "index"],
			"unknown"
		]
	},
	"ignorePatterns": [
		"AGENTS.md",
		".agents",
		".agents/**",
		".github/skills",
		".github/skills/**",
		"**/node_modules",
		"**/.next",
		"**/build",
		"**/dist",
		"**/.dist",
		"**/.react-email",
		"**/.turbo",
		"**/.vercel",
		"**/.workflow-data",
		"**/.well-known/workflow",
		"**/.vscode",
		"**/packages/db/src/db",
		"**/lint-staged.config.js",
		"**/.cursorrules",
		"**/expo-env.d.ts",
		"**/ios",
		"**/android",
		"**/.expo",
		"**/.expo-shared",
		"**/metro-cache",
		"**/coverage",
		"**/.cache",
		"**/storybook-static",
		"**/.husky",
		"**/.trigger",
		"**/*.min.js",
		"**/*.d.ts",
		"**/next-env.d.ts",
		"**/postcss.config.*",
		"**/bun.lockb",
		"**/*.lock",
		"skills-lock.json",
		"**/.git",
		"**/tmp",
		"**/.docker",
		"**/containers"
	]
}
