		}
	},
	"scripts": {
		"typecheck": "tsgo --noEmit --skipLibCheck"
	},
	"dependencies": {
		"@ai-sdk/devtools": "^1.0.0-beta.32",
		"ai": "^7.0.0-beta.179",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^26.0.0",
		"@webld/tsconfig": "workspace:*",
		"typescript": "^7.0.1-rc"
