		"sharp": "^0.35.3",
		"uuid": "^14.0.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/google.maps": "^3.65.2",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@webld/tsconfig": "workspace:*",
