		"@vectorstores/core": "^0.1.8",
		"@vectorstores/env": "^0.1.0",
		"@vectorstores/excel": "^0.1.8",
		"@vectorstores/readers": "^0.1.8",
		"@vercel/blob": "^2.5.0",
		"@vercel/functions": "^3.7.5",
		"@webld/ai": "workspace:*",
		"@webld/cache": "workspace:*",
