{
	"name": "@webld/server",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./hono": {
			"types": "./src/hono/app.ts",
			"import": "./src/hono/app.ts",
			"default": "./src/hono/app.ts"
		},
		"./openapi": {
			"types": "./src/hono/openapi.ts",
			"import": "./src/hono/openapi.ts",
			"default": "./src/hono/openapi.ts"
		},
		"./api-schemas": {
			"types": "./src/hono/schemas.ts",
			"import": "./src/hono/schemas.ts",
			"default": "./src/hono/schemas.ts"
		},
		"./auth": {
			"types": "./src/lib/auth.ts",
			"import": "./src/lib/auth.ts",
			"default": "./src/lib/auth.ts"
		},
		"./document-extraction": {
			"types": "./src/services/document-extraction.ts",
			"import": "./src/services/document-extraction.ts",
			"default": "./src/services/document-extraction.ts"
		},
		"./memory": {
			"types": "./src/services/memory.ts",
			"import": "./src/services/memory.ts",
			"default": "./src/services/memory.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit --skipLibCheck"
	},
	"dependencies": {
		"@ai-sdk/google": "^4.0.8",
		"@ai-sdk/workflow": "^1.0.14",
