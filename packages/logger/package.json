{
	"name": "@webld/logger",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"import": "./src/client.ts",
