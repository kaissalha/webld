	},
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@webld/tsconfig": "workspace:*",
		"typescript": "^7.0.1-rc"
	},
	"peerDependencies": {
		"react": "^19.2.5"
	}
